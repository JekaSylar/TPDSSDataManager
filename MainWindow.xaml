<Window x:Class="TPDSSDataManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ТП ДСС: Автоматизація ГУС у Донецькій області" 
        Height="700" Width="1050" 
        Background="#121212"
        WindowStartupLocation="CenterScreen" 
        Foreground="#E0E0E0"
        FontFamily="Segoe UI, Inter, sans-serif"
        ResizeMode="CanResize"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Єдиний стиль для всіх кнопок -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3700B3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#6200EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#03DAC6"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <!-- Коректний вигляд для НЕАКТИВНОЇ кнопки -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="btnBorder" Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#A0A0A0"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#181818"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="5,3"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#181818" Padding="10,6" BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
            <MenuItem Header="Розбивка бази" Click="MenuSplit_Click" Foreground="#E0E0E0" FontSize="13" Margin="0,0,8,0"/>
            <MenuItem Header="Об'єднання декількох баз" Click="MenuMerge_Click" Foreground="#E0E0E0" FontSize="13" Margin="0,0,8,0"/>
            <MenuItem Header="Тестування" Click="MenuTest_Click" Foreground="#FFB86C" FontSize="13" Margin="0,0,8,0"/>
            <MenuItem Header="Довідка" Click="MenuHelp_Click" Foreground="#E0E0E0" FontSize="13" Margin="0,0,8,0"/>
            <MenuItem Header="Вихід" Click="MenuExit_Click" Foreground="#E0E0E0" FontSize="13"/>
        </Menu>

        <StackPanel x:Name="StartScreen" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="📊" FontSize="70" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBlock Text="ТП ДСС: Автоматизація" FontSize="24" FontWeight="Bold" Foreground="#BB86FC" HorizontalAlignment="Center"/>
            <TextBlock Text="Оберіть режим роботи у верхньому меню" FontSize="14" Foreground="#888" Margin="0,10" HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid x:Name="GridSplit" Grid.Row="1" Margin="30,20" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Розбивка бази" FontSize="22" FontWeight="SemiBold" Foreground="#03DAC6" Margin="0,0,0,30"/>

                <TextBlock Text="Крок 1: Оберіть файл бази" Foreground="#AAA" FontSize="13" Margin="0,0,0,8"/>
                <Button Content="📁 Обрати файл" Style="{StaticResource ModernButtonStyle}" Click="BtnSelectSource_Click" HorizontalAlignment="Stretch"/>
                <TextBlock x:Name="TxtSourcePath" Text="Файл не обрано" Foreground="#777" Margin="5,8,0,30" FontSize="12" TextWrapping="Wrap"/>

                <TextBlock Text="Крок 2: Запуск процесу" Foreground="#AAA" FontSize="13" Margin="0,0,0,8"/>
                <Button x:Name="BtnRunSplit" Content="🚀 Почати розбивку" Style="{StaticResource ModernButtonStyle}" 
                        Background="#03DAC6" Foreground="Black" Click="BtnRunSplit_Click" IsEnabled="False" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#181818" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="8" Padding="15" x:Name="TreePanel" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="ChkSelectAll" Content="Відмітити всі / Зняти всі" IsChecked="True" Foreground="#03DAC6" FontWeight="SemiBold" FontSize="14" Margin="5,0,0,15" Click="ChkSelectAll_Click"/>

                    <TreeView x:Name="TreeSSP" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="#E0E0E0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Margin" Value="0,3"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <CheckBox IsChecked="{Binding IsChecked}" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,2">
                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                </CheckBox>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="GridMerge" Grid.Row="1" Margin="50,30" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Об'єднання декількох баз" FontSize="22" FontWeight="SemiBold" Foreground="#CF6679" Margin="0,0,0,20"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                <Button Content="➕ Додати файли (або перетягніть нижче)" Style="{StaticResource ModernButtonStyle}" Click="BtnAddMergeFiles_Click"/>
                <!-- ТУТ БУЛА ПОМИЛКА: додано Style -->
                <Button x:Name="BtnClearMergeFiles" Content="🗑 Очистити" Style="{StaticResource ModernButtonStyle}" Background="#CF6679" Margin="10,0,0,0" Click="BtnClearMergeFiles_Click"/>
            </StackPanel>

            <ListBox Grid.Row="2" x:Name="ListMergeFiles" Margin="0,10" 
                     AllowDrop="True" 
                     DragEnter="ListMergeFiles_DragEnter" 
                     Drop="ListMergeFiles_Drop"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5,0,0">
                <Button x:Name="BtnRunMerge" Content="🔗 Об'єднати все в один файл" Style="{StaticResource ModernButtonStyle}" 
                        Background="#CF6679" Foreground="Black" Click="BtnRunMerge_Click" IsEnabled="False" />
                <Button x:Name="BtnCancelMerge" Content="🛑 Скасувати" Style="{StaticResource ModernButtonStyle}" 
                        Background="#CF6679" Click="BtnCancelMerge_Click" IsEnabled="False" Margin="10,0,0,0"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="GridTest" Grid.Row="1" Margin="30,20" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Тестування склейки" FontSize="22" FontWeight="SemiBold" Foreground="#FFB86C" Margin="0,0,0,20"/>

                <TextBlock Text="1. Фінальна (склеєна) база:" Foreground="#AAA" FontSize="13" Margin="0,0,0,5"/>
                <Button Content="📁 Обрати фінальну БД" Style="{StaticResource ModernButtonStyle}" Background="#FFB86C" Foreground="Black" Click="BtnSelectTestMerged_Click" HorizontalAlignment="Stretch"/>
                <TextBlock x:Name="TxtTestMergedPath" Text="Файл не обрано" Foreground="#777" Margin="5,5,0,20" FontSize="12" TextWrapping="Wrap"/>

                <TextBlock Text="2. Вихідні шматки (які клеїли):" Foreground="#AAA" FontSize="13" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <Button Content="➕ Додати" Style="{StaticResource ModernButtonStyle}" Padding="15,5" MinHeight="30" Click="BtnAddTestFiles_Click"/>
                    <!-- ТУТ БУЛА ПОМИЛКА: додано Style -->
                    <Button Content="🗑 Очистити" Style="{StaticResource ModernButtonStyle}" Background="#CF6679" Padding="15,5" MinHeight="30" Margin="10,0,0,0" Click="BtnClearTestFiles_Click"/>
                </StackPanel>
                <ListBox x:Name="ListTestFiles" Height="150" Margin="0,0,0,20" AllowDrop="True" DragEnter="ListTestFiles_DragEnter" Drop="ListTestFiles_Drop"/>

                <TextBlock Text="3. Запуск порівняння:" Foreground="#AAA" FontSize="13" Margin="0,0,0,5"/>
                <Button x:Name="BtnRunTest" Content="🔍 Знайти втрачені рядки" Style="{StaticResource ModernButtonStyle}"
                        Background="#FFB86C" Foreground="Black" Click="BtnRunTest_Click" IsEnabled="False" HorizontalAlignment="Stretch"/>
            </StackPanel>

            <Border Grid.Column="1" Background="#181818" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="8" Padding="10">
                <TextBox x:Name="TxtTestReport" IsReadOnly="True" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"
                         Text="Тут з'явиться детальний звіт про те, яких ID не вистачає у склеєній базі..."/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#181818" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <ProgressBar x:Name="MainProgress" IsIndeterminate="True" Height="3" VerticalAlignment="Top" Foreground="#BB86FC" Background="Transparent" BorderThickness="0" Visibility="Collapsed"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtStatus" Text="Готово до роботи" Foreground="#999" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtSubStatus" Text="" FontSize="11" Foreground="#666" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>